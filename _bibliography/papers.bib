                  with Derivative-Informed Latent Attention Neural Operator},
  author       = {Go, Jinwoo and Chen, Peng},
  journal      = {Journal of Computational Physics},
  volume       = {521},
  pages        = {113976},
  year         = {2025},
  html         = {https://doi.org/10.1016/j.jcp.2025.113976},
  selected     = {true},
  abbr         = {JCP},
